meta {
  name: List Conversations
  type: http
  seq: 2
}

get {
  url: {{baseUrl}}/public/rag/conversations?userId={{userId}}&limit=50
  body: none
  auth: none
}

headers {
  Accept: application/json
}

tests {
  test("lists the test conversation", function() {
    expect(res.status).to.equal(200);
    expect(res.body.data.conversations).to.be.an("array");
    const ids = res.body.data.conversations.map(function(item) {
      return item.conversationId;
    });
    expect(ids).to.include(bru.getEnvVar("conversationId"));
  });
}
