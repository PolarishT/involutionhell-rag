meta {
  name: Metrics
  type: http
  seq: 3
}

get {
  url: {{baseUrl}}/actuator/metrics
  body: none
  auth: none
}

headers {
  Accept: application/json
}

tests {
  test("metrics endpoint exposes metric names", function() {
    expect(res.status).to.equal(200);
    expect(res.body.names).to.be.an("array");
  });
}
